<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_sudoku"/>

    <TextView
        android:id="@+id/tv_stat_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thống kê chi tiết"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/text_main"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/card_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/tv_stat_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="1,2,3">

            <!-- Header row -->
            <TableRow
                android:background="@color/text_main"
                android:paddingVertical="14dp">
                <TextView
                    android:text="DANH\nMỤC"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:layout_gravity="center_vertical"/>
                <TextView
                    android:text="DỄ"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:gravity="center"/>
                <TextView
                    android:text="TRUNG\nBÌNH"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:gravity="center"/>
                <TextView
                    android:text="KHÓ"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingEnd="8dp"/>
            </TableRow>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_color"/>

            <!-- Điểm cao nhất -->
            <TableRow android:paddingVertical="16dp" android:background="@color/white">
                <TextView
                    android:text="ĐIỂM\nCAO\nNHẤT"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:layout_gravity="center_vertical"/>
                <TextView
                    android:id="@+id/tv_easy_score"
                    android:text="0"
                    android:textSize="15sp"
                    android:textColor="#0284C7"
                    android:textStyle="bold"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/tv_med_score"
                    android:text="0"
                    android:textSize="15sp"
                    android:textColor="#0284C7"
                    android:textStyle="bold"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/tv_hard_score"
                    android:text="0"
                    android:textSize="15sp"
                    android:textColor="#0284C7"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingEnd="8dp"/>
            </TableRow>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_color"/>

            <!-- Thời gian -->
            <TableRow android:paddingVertical="16dp" android:background="@color/white">
                <TextView
                    android:text="THỜI\nGIAN"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:layout_gravity="center_vertical"/>
                <TextView
                    android:id="@+id/tv_easy_time"
                    android:text="–"
                    android:textSize="15sp"
                    android:textColor="@color/text_main"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/tv_med_time"
                    android:text="–"
                    android:textSize="15sp"
                    android:textColor="@color/text_main"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/tv_hard_time"
                    android:text="–"
                    android:textSize="15sp"
                    android:textColor="@color/text_main"
                    android:gravity="center"
                    android:paddingEnd="8dp"/>
            </TableRow>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_color"/>

            <!-- Số lần gợi ý -->
            <TableRow android:paddingVertical="16dp" android:background="@color/white">
                <TextView
                    android:text="SỐ LẦN\nGỢI Ý"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:layout_gravity="center_vertical"/>
                <TextView
                    android:id="@+id/tv_easy_hints"
                    android:text="0"
                    android:textSize="15sp"
                    android:textColor="#B91C1C"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/tv_med_hints"
                    android:text="0"
                    android:textSize="15sp"
                    android:textColor="#B91C1C"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/tv_hard_hints"
                    android:text="0"
                    android:textSize="15sp"
                    android:textColor="#B91C1C"
                    android:gravity="center"
                    android:paddingEnd="8dp"/>
            </TableRow>

        </TableLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="By TBT"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <!-- Thanh tiêu đề + nút Home/Back -->
    <include layout="@layout/toolbar_sudoku"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn chế độ"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"/>

    <Button android:id="@+id/btn_easy"
        android:layout_width="240dp" android:layout_height="60dp"
        android:text="Dễ" android:textSize="18sp"
        android:layout_marginBottom="20dp"/>

    <Button android:id="@+id/btn_medium"
        android:layout_width="240dp" android:layout_height="60dp"
        android:text="Trung Bình" android:textSize="18sp"
        android:layout_marginBottom="20dp"/>

    <Button android:id="@+id/btn_hard"
        android:layout_width="240dp" android:layout_height="60dp"
        android:text="Khó" android:textSize="18sp"/>
</LinearLayout>
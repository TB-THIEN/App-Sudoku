<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hướng dẫn chơi"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:layout_marginBottom="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <TextView
            android:id="@+id/tv_guide_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.5"
            android:text="• Điền các số từ 1 đến 9 vào lưới 9x9.\n\n• Mỗi hàng, mỗi cột và mỗi vùng 3x3 chỉ được chứa mỗi số một lần.\n\n• Nhấn vào ô muốn điền, sau đó nhấn số trên bàn phím.\n\n• Nút Gợi ý: tự động điền 1 ô đúng (giới hạn 3 lần).\n\n• Nút Tự giải: điền đáp án toàn bộ.\n\n• Ô màu đỏ: số bạn nhập bị sai.\n\n• Công thức điểm: Điểm gốc - (giây × 2) - (gợi ý × 200)"/>
    </ScrollView>

    <Button
        android:id="@+id/btn_back"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Quay lại"
        android:backgroundTint="@color/colorPrimary"
        android:layout_marginTop="16dp"/>
</LinearLayout>